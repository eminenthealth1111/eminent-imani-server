# ═══════════════════════════════════════════════════════
# EMINENT IMANI — RAILWAY ENVIRONMENT VARIABLES
# Add each of these in Railway → Your Project → Variables
# DO NOT commit this file to GitHub
# ═══════════════════════════════════════════════════════

# ── Google OAuth2 ───────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
GOOGLE_REFRESH_TOKEN=your_refresh_token_from_oauth_playground_here

# ── Google Calendar ─────────────────────────────────────
# Leave as "primary" to use your main Google Calendar
GOOGLE_CALENDAR_ID=primary

# ── Gmail ───────────────────────────────────────────────
# The Gmail account sending confirmation emails
GMAIL_USER=your-gmail-address@gmail.com

# ── Internal Notifications ──────────────────────────────
# Where lead alerts and after-hours messages get sent
# Can be the same as GMAIL_USER or a different address
INTERNAL_EMAIL=your-internal-email@gmail.com
